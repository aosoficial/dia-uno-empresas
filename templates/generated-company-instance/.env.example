# Copy to a private .env outside public Git if needed.
# Do not commit real secrets.

HERMES_PROFILE=
MODEL_PROVIDER=
MODEL_NAME=

# Private memory must be ready before launching CEO.
# Keep real values in a private secrets manager or local profile env, never in Git/chat.
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
SUPABASE_SCHEMA=gbrain
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large
GBRAIN_REPO_URL=https://github.com/garrytan/gbrain
GBRAIN_INSTALL_DIR=
GBRAIN_COMMAND=gbrain
GBRAIN_MCP_SERVER=
GBRAIN_MCP_NAME=
GBRAIN_PROJECT_ID=
GBRAIN_NAMESPACE=
GBRAIN_COMPANY_ID=

# Slack -> Hermes Socket Mode.
# Keep real values in the Hermes profile .env or a private secrets manager.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USERS=
SLACK_ALLOWED_CHANNELS=
SLACK_HOME_CHANNEL=
SLACK_REQUIRE_MENTION=true
SLACK_STRICT_MENTION=true
